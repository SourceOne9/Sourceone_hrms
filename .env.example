# ── EMS Pro Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in values

# ── Django Backend ──
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
DJANGO_INTERNAL_URL=                          # Server-to-server Django URL (production)
DJANGO_GATEWAY_URL=                           # API gateway URL (production load balancer)
DJANGO_SERVICE_TOKEN=                         # Required: Server→Django auth for metrics, RBAC, search, workflows, webhooks

# ── Authentication ──
AUTH_SECRET=                                  # NextAuth secret (legacy, being phased out)
NEXTAUTH_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=                                 # PostgreSQL connection string (Supabase)

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Auth0 (optional) ──
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_ISSUER=

# ── AI ──
GEMINI_API_KEY=                               # Google Gemini AI for chatbot

# ── Redis Cache ──
UPSTASH_REDIS_REST_URL=                       # Falls back to in-memory if empty
UPSTASH_REDIS_REST_TOKEN=

# ── Supabase Storage (optional) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Resend) ──
RESEND_API_KEY=                               # Optional: disables email if empty
EMAIL_FROM=EMS Pro <noreply@ems-pro.app>

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Cron & SCIM ──
CRON_SECRET=                                  # Bearer token for cron endpoints (32+ chars)
SCIM_TOKEN=                                   # Bearer token for SCIM provisioning (32+ chars)

# ── Embedding Mode (optional) ──
NEXT_PUBLIC_EMBEDDED=                         # Set to "true" for HiringNow platform embedding
NEXT_PUBLIC_BASE_PATH=                        # URL prefix when embedded (e.g., /hrms)

# ── E2E Testing (gitignored, use .env.test) ──
# TEST_TENANT=
# TEST_EMAIL=
# TEST_PASSWORD=
