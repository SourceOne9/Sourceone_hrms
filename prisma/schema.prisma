generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  hashedPassword     String
  role               Role      @default(EMPLOYEE)
  avatar             String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  accentColor        String?   @default("blue")
  bio                String?
  lastLoginAt        DateTime?
  mustChangePassword Boolean   @default(false)
  employee           Employee?
}

model Department {
  id         String      @id @default(cuid())
  name       String      @unique
  color      String?
  createdAt  DateTime    @default(now())
  candidates Candidate[]
  employees  Employee[]
}

model Employee {
  id                 String               @id @default(cuid())
  employeeCode       String               @unique
  firstName          String
  lastName           String
  email              String               @unique
  phone              String?
  designation        String
  departmentId       String
  dateOfJoining      DateTime
  salary             Float
  status             EmployeeStatus       @default(ACTIVE)
  avatarUrl          String?
  address            String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  userId             String?              @unique
  managerId          String?
  assets             Asset[]
  attendanceRecords  Attendance[]
  documents          Document[]
  department         Department           @relation(fields: [departmentId], references: [id])
  manager            Employee?            @relation("EmployeeToManager", fields: [managerId], references: [id])
  reports            Employee[]           @relation("EmployeeToManager")
  user               User?                @relation(fields: [userId], references: [id])
  leaves             Leave[]
  payrollRecords     Payroll[]
  performanceReviews PerformanceReview[]
  pfRecords          ProvidentFund[]
  resignations       Resignation[]
  tickets            Ticket[]
  trainings          TrainingEnrollment[]
}

model Asset {
  id           String      @id @default(cuid())
  name         String
  type         AssetType
  serialNumber String      @unique
  status       AssetStatus @default(AVAILABLE)
  purchaseDate DateTime
  value        Float
  image        String?
  assignedToId String?
  assignedDate DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  assignedTo   Employee?   @relation(fields: [assignedToId], references: [id])
}

model Document {
  id         String      @id @default(cuid())
  title      String
  category   DocCategory
  url        String
  size       String?
  isPublic   Boolean     @default(false)
  employeeId String?
  uploadDate DateTime    @default(now())
  employee   Employee?   @relation(fields: [employeeId], references: [id])
}

model Leave {
  id         String      @id @default(cuid())
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveStatus @default(PENDING)
  employeeId String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  employee   Employee    @relation(fields: [employeeId], references: [id])
}

model Resignation {
  id         String            @id @default(cuid())
  reason     String
  lastDay    DateTime
  status     ResignationStatus @default(UNDER_REVIEW)
  employeeId String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  employee   Employee          @relation(fields: [employeeId], references: [id])
}

model Attendance {
  id         String           @id @default(cuid())
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  workHours  Float?
  status     AttendanceStatus @default(PRESENT)
  employeeId String
  createdAt  DateTime         @default(now())
  employee   Employee         @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id          String        @id @default(cuid())
  month       String
  basicSalary Float
  allowances  Float         @default(0)
  pfDeduction Float         @default(0)
  tax         Float         @default(0)
  otherDed    Float         @default(0)
  netSalary   Float
  status      PayrollStatus @default(PENDING)
  employeeId  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employee    Employee      @relation(fields: [employeeId], references: [id])
}

model ProvidentFund {
  id                   String   @id @default(cuid())
  month                String
  accountNumber        String
  basicSalary          Float
  employeeContribution Float
  employerContribution Float
  totalContribution    Float
  status               String   @default("Credited")
  employeeId           String
  createdAt            DateTime @default(now())
  employee             Employee @relation(fields: [employeeId], references: [id])
}

model PerformanceReview {
  id         String            @id @default(cuid())
  rating     Float
  progress   Int               @default(0)
  comments   String?
  reviewDate DateTime          @default(now())
  status     PerformanceStatus @default(PENDING)
  employeeId String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  employee   Employee          @relation(fields: [employeeId], references: [id])
}

model Training {
  id           String               @id @default(cuid())
  name         String
  type         TrainingType
  description  String?
  status       TrainingStatus       @default(UPCOMING)
  progress     Int                  @default(0)
  dueDate      DateTime?
  participants Int                  @default(0)
  videoUrl     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  enrollments  TrainingEnrollment[]
}

model TrainingEnrollment {
  id         String   @id @default(cuid())
  score      Int?
  completed  Boolean  @default(false)
  trainingId String
  employeeId String
  enrolledAt DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
  training   Training @relation(fields: [trainingId], references: [id])

  @@unique([trainingId, employeeId])
}

model Announcement {
  id        String               @id @default(cuid())
  title     String
  content   String
  author    String
  category  AnnouncementCategory
  priority  AnnouncementPriority @default(MEDIUM)
  isPinned  Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model Ticket {
  id          String         @id @default(cuid())
  ticketCode  String         @unique
  subject     String
  description String?
  category    TicketCategory
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  employeeId  String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  employee    Employee       @relation(fields: [employeeId], references: [id])
}

model CalendarEvent {
  id        String    @id @default(cuid())
  title     String
  start     DateTime
  end       DateTime
  allDay    Boolean   @default(false)
  type      EventType @default(EVENT)
  createdAt DateTime  @default(now())
}

model Candidate {
  id            String          @id @default(cuid())
  name          String
  email         String
  phone         String?
  role          String
  stage         CandidateStage  @default(APPLICATION)
  status        CandidateStatus @default(NEW)
  interviewDate DateTime?
  notes         String?
  departmentId  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  department    Department?     @relation(fields: [departmentId], references: [id])
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
}

enum AssetType {
  HARDWARE
  SOFTWARE
  ACCESSORY
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum DocCategory {
  POLICY
  CONTRACT
  PAYSLIP
  TAX
  IDENTIFICATION
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ResignationStatus {
  UNDER_REVIEW
  NOTICE_PERIOD
  PROCESSED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  WEEKEND
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
}

enum PerformanceStatus {
  PENDING
  COMPLETED
  EXCELLENT
  GOOD
  NEEDS_IMPROVEMENT
}

enum TrainingType {
  TECHNICAL
  COMPLIANCE
  SECURITY
  SOFT_SKILLS
  LEADERSHIP
}

enum TrainingStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
}

enum AnnouncementCategory {
  EVENT
  POLICY
  MEETING
  SYSTEM
  GENERAL
}

enum AnnouncementPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketCategory {
  IT
  HR
  FINANCE
  FACILITIES
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum EventType {
  HOLIDAY
  LEAVE
  BIRTHDAY
  EVENT
  MEETING
}

enum CandidateStage {
  APPLICATION
  SCREENING
  INTERVIEW
  TECHNICAL_ROUND
  OFFER
  HIRED
  REJECTED
}

enum CandidateStatus {
  NEW
  SCHEDULED
  EVALUATED
  PENDING
  ACCEPTED
  REJECTED
}
